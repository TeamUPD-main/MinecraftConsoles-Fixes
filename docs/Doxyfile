#---------------------------------------------------------------------------
# File Config
#---------------------------------------------------------------------------
PROJECT_NAME           = "MinecraftConsoles-Fixes"
INPUT                  = ../Minecraft.Assets \
                         ../Minecraft.Client \
                         ../Minecraft.World  \
                         ./doxymain.md
RECURSIVE              = YES
